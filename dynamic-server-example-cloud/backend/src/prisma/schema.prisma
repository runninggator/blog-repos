generator client {
  provider      = "prisma-client"
  output        = "generated/prisma"
  binaryTargets = ["rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
}

model User { 
  id        Int     @id @default(autoincrement()) 
  email     String  @unique
  name      String?
  hashedPwd String
}